# =====================================================================
# Configuración de la automatización diaria de Dropi
# ---------------------------------------------------------------------
# 1) Copia este archivo a:  config.local.env  (en la misma carpeta)
# 2) Rellena los valores reales.
# 3) NUNCA compartas config.local.env: tiene tus contraseñas.
# =====================================================================

# --- Cuenta de Dropi (la que usas para entrar a app.dropi.co) ---
DROPI_EMAIL=tu-correo@gmail.com
DROPI_PASSWORD=pon-aqui-tu-password

# País de la cuenta Dropi (CO = Colombia). Define la URL de la API.
DROPI_COUNTRY=CO

# --- Telegram (lo creamos con @BotFather) ---
TELEGRAM_BOT_TOKEN=123456:ABC-pon-aqui-el-token-del-bot
TELEGRAM_CHAT_ID=pon-aqui-tu-chat-id

# --- Parámetros del reporte ---
# Cuántos días hacia atrás se traen las órdenes en cada corrida.
DROPI_WINDOW_DAYS=45

# Zona horaria para fechas y horario del reporte.
TZ=America/Bogota
